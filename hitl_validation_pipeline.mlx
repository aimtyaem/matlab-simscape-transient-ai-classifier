%% HITL Validation & Fine‑Tuning Pipeline (Claude Fable 5 → Opus)
% 1. Run the Simscape simulation and extract features.
% 2. Label with Claude Fable 5, escalate to Opus if confidence < 80 %.
% 3. If final confidence still low, launch human review and save correction.

% --- Step 1: Run simulation (creates payload, time, pressure, etc.) ---
run('simulate_and_extract_features.mlx');

% --- Step 2: Query Claude with escalation (Fable 5 → Opus) ---
aiResult = query_with_escalation(payload);

% --- Step 3: Confidence check & Human‑in‑the‑Loop ---
threshold = 0.80;
userCorrectionRequired = false;

if aiResult.confidence_score < threshold
    fprintf('\n[WARNING] Final AI confidence low (%.2f). Launching human review...\n', ...
        aiResult.confidence_score);
    userCorrectionRequired = true;
else
    fprintf('\nAI auto‑labeled simulation: "%s" (confidence: %.2f)\n', ...
        aiResult.regime_classification, aiResult.confidence_score);
end

% --- Step 4: Human expert review and fine‑tuning dataset update ---
if userCorrectionRequired
    % Show transient curve for expert review
    figure('Name', 'HITL Signal Verification Portal');
    plot(time, pressure, 'LineWidth', 2, 'Color', '#D95319');
    grid on;
    title(sprintf('Transient Pressure Dynamics (\\DeltaP = %.1f Pa)', deltaP));
    xlabel('Time (s)');
    ylabel('Pressure (Pa)');

    % Prompt engineer via command window
    disp('Select the correct physical regime:');
    disp('1: Safe Operation');
    disp('2: Water Hammer Surge');
    disp('3: Cavitation Risk');
    choice = input('Enter index (1-3): ');

    regimes = {'Safe Operation', 'Water Hammer Surge', 'Cavitation Risk'};
    correctedLabel = regimes{choice};

    % Build fine‑tuning record (JSONL)
    ft_record = struct(...
        'messages', {{ ...
            struct('role', 'system', 'content', 'You are an expert engineering data labeler.'), ...
            struct('role', 'user', 'content', payload), ...
            struct('role', 'assistant', 'content', ...
                sprintf('{"regime_classification": "%s"}', correctedLabel)) ...
        }} ...
    );

    % Append to fine‑tuning dataset
    fid = fopen('fine_tuning_dataset.jsonl', 'a');
    if fid == -1
        error('Cannot open fine_tuning_dataset.jsonl for writing.');
    end
    fprintf(fid, '%s\n', jsonencode(ft_record));
    fclose(fid);

    fprintf('Data point manually validated and logged to fine_tuning_dataset.jsonl\n');
else
    fprintf('Validation succeeded. No human labeling required.\n');
end

%% Local Function: Two‑Model Escalation (Fable 5 → Opus)
function finalLabel = query_with_escalation(jsonPayload)
    % Step A: Fast label with Claude Fable 5
    fableResult = query_ai_labeler(jsonPayload, 'claude-fable-5');
    fprintf('Fable 5 classification: "%s" (confidence: %.2f)\n', ...
        fableResult.regime_classification, fableResult.confidence_score);

    % If confidence is below 80%, escalate to Claude Opus
    if fableResult.confidence_score < 0.80
        fprintf('Confidence below 80%%. Escalating to Claude Opus...\n');
        opusResult = query_ai_labeler(jsonPayload, 'claude-opus-4-20250514');
        finalLabel = opusResult;
    else
        finalLabel = fableResult;
    end
end